        "overflow_error", "underflow_error"
    };
    
    return types.find(word) != types.end();
}

bool CodeEditor::isNumber(const std::string& word) const {
    if (word.empty()) return false;
    
    size_t start = 0;
    if (word[0] == '-' || word[0] == '+') start = 1;
    if (start >= word.length()) return false;
    
    // Check for hexadecimal numbers (0x or 0X)
    if (start + 2 < word.length() && word[start] == '0' && 
        (word[start + 1] == 'x' || word[start + 1] == 'X')) {
        for (size_t i = start + 2; i < word.length(); i++) {
            char c = std::tolower(word[i]);
            if (!std::isdigit(c) && (c < 'a' || c > 'f')) {
                // Check for suffix
                if (i == word.length() - 1 && (c == 'l' || c == 'u')) continue;
                if (i == word.length() - 2 && c == 'u' && std::tolower(word[i + 1]) == 'l') {
                    i++; continue;
                }
                if (i == word.length() - 2 && c == 'l' && std::tolower(word[i + 1]) == 'l') {
                    i++; continue;
                }
                return false;
            }
        }
        return true;
    }
    
    // Check for binary numbers (0b or 0B)
    if (start + 2 < word.length() && word[start] == '0' && 
        (word[start + 1] == 'b' || word[start + 1] == 'B')) {
        for (size_t i = start + 2; i < word.length(); i++) {
            char c = word[i];
            if (c != '0' && c != '1') {
                // Check for suffix
                if (i == word.length() - 1 && (c == 'l' || c == 'L' || c == 'u' || c == 'U')) continue;
                return false;
            }
        }
        return true;
    }
    
    // Check for octal numbers (starting with 0)
    if (word[start] == '0' && word.length() > start + 1) {
        for (size_t i = start + 1; i < word.length(); i++) {
            char c = word[i];
            if (c < '0' || c > '7') {
                // Check for suffix or decimal point
                if (c == '.' || c == 'e' || c == 'E') break; // Fall through to decimal check
                if (i == word.length() - 1 && (c == 'l' || c == 'L' || c == 'u' || c == 'U')) continue;
                if (i == word.length() - 2) {
                    char next = word[i + 1];
                    if ((c == 'u' || c == 'U') && (next == 'l' || next == 'L')) {
                        i++; continue;
                    }
                    if ((c == 'l' || c == 'L') && (next == 'l' || next == 'L')) {
                        i++; continue;
                    }
                }
                return false;
            }
        }
        // If we got here without hitting decimal/exponent, it's a valid octal
        if (word.find('.') == std::string::npos && word.find('e') == std::string::npos && word.find('E') == std::string::npos) {
            return true;
        }
    }
    
    // Check for decimal numbers
    bool hasDecimal = false;
    bool hasExponent = false;
    
    for (size_t i = start; i < word.length(); i++) {
        char c = word[i];
        
        if (std::isdigit(c)) continue;
        
        if (c == '.' && !hasDecimal && !hasExponent) {
            hasDecimal = true;
            continue;
        }
        
        if ((c == 'e' || c == 'E') && !hasExponent && i > start) {
            hasExponent = true;
            if (i + 1 < word.length() && (word[i + 1] == '+' || word[i + 1] == '-')) {
                i++;
            }
            continue;
        }
        
        // Check for numeric suffixes
        if (i == word.length() - 1) {
            if (c == 'f' || c == 'F' || c == 'l' || c == 'L' || c == 'u' || c == 'U') {
                continue;
            }
        }
        
        // Check for compound suffixes like UL, LL, etc.
        if (i == word.length() - 2) {
            char next = word[i + 1];
            if ((c == 'u' || c == 'U') && (next == 'l' || next == 'L')) {
                i++; continue;
            }
            if ((c == 'l' || c == 'L') && (next == 'l' || next == 'L')) {
                i++; continue;
            }
        }
        
        return false;
    }
    
    return start < word.length();
}

bool CodeEditor::isString(const std::string& word) const {
    return word.length() >= 2 && 
           ((word[0] == '"' && word.back() == '"') || 
            (word[0] == '\'' && word.back() == '\''));
}

// Find and replace
void CodeEditor::find(const std::string& text) {
    searchText = text;
    searchResults.clear();
    currentSearchResult = -1;
    
    if (text.empty()) return;
    
    for (int line = 0; line < (int)lines.size(); line++) {
        size_t pos = 0;
        while ((pos = lines[line].find(text, pos)) != std::string::npos) {
            searchResults.emplace_back(line, (int)pos);
            pos++;
        }
    }
    
    if (!searchResults.empty()) {
        currentSearchResult = 0;
        setCursor(searchResults[0], false);
        selection.set(searchResults[0], 
                     Position(searchResults[0].line, 
                             searchResults[0].column + (int)text.length()));
    }
}

void CodeEditor::replace(const std::string& findText, const std::string& replaceText) {
    if (selection.active && getSelectedText() == findText) {
        deleteSelection();
        insertText(replaceText);
    }
}