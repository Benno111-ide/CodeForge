void CodeEditor::setCursorPosition(const Position& pos) { 
    cursorPos = pos;
    // Clamp cursor position to valid bounds
    if (cursorPos.line < 0) cursorPos.line = 0;
    if (cursorPos.line >= (int)lines.size()) cursorPos.line = (int)lines.size() - 1;
    if (cursorPos.line >= 0 && cursorPos.line < (int)lines.size()) {
        if (cursorPos.column < 0) cursorPos.column = 0;
        if (cursorPos.column > (int)lines[cursorPos.line].length()) {
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
}

void CodeEditor::moveCursor(int deltaLine, int deltaColumn) {
    Position newPos = Position(cursorPos.line + deltaLine, cursorPos.column + deltaColumn);
    setCursorPosition(newPos);
}

// Helper methods for cursor movement and text editing
void CodeEditor::insertCharacterAtCursor(char c) {
    if (lines.empty()) {
        lines.push_back("");
    }
    
    // Ensure cursor is within valid bounds
    if (cursorPos.line >= (int)lines.size()) {
        cursorPos.line = (int)lines.size() - 1;
    }
    if (cursorPos.line < 0) {
        cursorPos.line = 0;
    }
    
    if (cursorPos.line < (int)lines.size()) {
        if (c == '\n') {
            // Split line at cursor
            std::string rightPart = lines[cursorPos.line].substr(cursorPos.column);
            lines[cursorPos.line] = lines[cursorPos.line].substr(0, cursorPos.column);
            cursorPos.line++;
            cursorPos.column = 0;
            lines.insert(lines.begin() + cursorPos.line, rightPart);
        } else {
            lines[cursorPos.line].insert(cursorPos.column, 1, c);
            cursorPos.column++;
        }
        modified = true;
        rebuildContent();
    }
}

void CodeEditor::backspaceAtCursor() {
    if (lines.empty()) return;
    
    if (cursorPos.column > 0) {
        lines[cursorPos.line].erase(cursorPos.column - 1, 1);
        cursorPos.column--;
        modified = true;
        rebuildContent();
    } else if (cursorPos.line > 0) {
        // Join with previous line
        cursorPos.column = (int)lines[cursorPos.line - 1].length();
        lines[cursorPos.line - 1] += lines[cursorPos.line];
        lines.erase(lines.begin() + cursorPos.line);
        cursorPos.line--;
        modified = true;
        rebuildContent();
    }
}

void CodeEditor::deleteAtCursor() {
    if (lines.empty()) return;
    
    if (cursorPos.line < (int)lines.size()) {
        if (cursorPos.column < (int)lines[cursorPos.line].length()) {
            lines[cursorPos.line].erase(cursorPos.column, 1);
            modified = true;
            rebuildContent();
        } else if (cursorPos.line < (int)lines.size() - 1) {
            // Join with next line
            lines[cursorPos.line] += lines[cursorPos.line + 1];
            lines.erase(lines.begin() + cursorPos.line + 1);
            modified = true;
            rebuildContent();
        }
    }
}

void CodeEditor::moveCursorLeft() {
    moveCursorLeft(false);
}

void CodeEditor::moveCursorLeft(bool extend) {
    Position oldPos = cursorPos;
    
    if (cursorPos.column > 0) {
        cursorPos.column--;
    } else if (cursorPos.line > 0) {
        cursorPos.line--;
        if (cursorPos.line < (int)lines.size()) {
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
    
    updateSelection(oldPos, extend);
}

void CodeEditor::moveCursorRight() {
    moveCursorRight(false);
}

void CodeEditor::moveCursorRight(bool extend) {
    Position oldPos = cursorPos;
    
    if (!lines.empty() && cursorPos.line < (int)lines.size()) {
        if (cursorPos.column < (int)lines[cursorPos.line].length()) {
            cursorPos.column++;
        } else if (cursorPos.line < (int)lines.size() - 1) {
            cursorPos.line++;
            cursorPos.column = 0;
        }
    }
    
    updateSelection(oldPos, extend);
}

void CodeEditor::moveCursorUp() {
    moveCursorUp(false);
}

void CodeEditor::moveCursorUp(bool extend) {
    Position oldPos = cursorPos;
    
    if (cursorPos.line > 0) {
        cursorPos.line--;
        if (cursorPos.line < (int)lines.size()) {
            if (cursorPos.column > (int)lines[cursorPos.line].length()) {
                cursorPos.column = (int)lines[cursorPos.line].length();
            }
        }
    }
    
    updateSelection(oldPos, extend);
    ensureCursorVisible();
}

void CodeEditor::moveCursorDown() {
    moveCursorDown(false);
}

void CodeEditor::moveCursorDown(bool extend) {
    Position oldPos = cursorPos;
    
    if (!lines.empty() && cursorPos.line < (int)lines.size() - 1) {
        cursorPos.line++;
        if (cursorPos.column > (int)lines[cursorPos.line].length()) {
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
    
    updateSelection(oldPos, extend);
    ensureCursorVisible();
}

void CodeEditor::rebuildContent() {
    content.clear();
    for (size_t i = 0; i < lines.size(); ++i) {
        content += lines[i];
        if (i < lines.size() - 1) {
            content += "\n";
        }
    }
    
    // Invalidate line width cache when content changes
    lineCacheDirty = true;
}
