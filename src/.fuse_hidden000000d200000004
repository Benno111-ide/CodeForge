void CodeEditor::deleteSelection() { 
    if (!hasSelection || readOnlyMode) return;
    
    Position start = selectionStart;
    Position end = selectionEnd;
    
    // Ensure start comes before end
    if (start.line > end.line || (start.line == end.line && start.column > end.column)) {
        std::swap(start, end);
    }
    
    if (start.line == end.line) {
        // Single line selection
        if (start.line < (int)lines.size()) {
            lines[start.line].erase(start.column, end.column - start.column);
        }
    } else {
        // Multi-line selection
        if (start.line < (int)lines.size() && end.line < (int)lines.size()) {
            // Keep the part before selection on first line
            std::string firstPart = lines[start.line].substr(0, start.column);
            // Keep the part after selection on last line  
            std::string lastPart = lines[end.line].substr(end.column);
            
            // Remove all lines in between
            lines.erase(lines.begin() + start.line, lines.begin() + end.line + 1);
            
            // Insert the combined line
            lines.insert(lines.begin() + start.line, firstPart + lastPart);
        }
    }
    
    cursorPos = start;
    hasSelection = false;
    modified = true;
    rebuildContent();
}

std::string CodeEditor::getSelectedText() const {
    if (!hasSelection) return "";
    
    Position start = selectionStart;
    Position end = selectionEnd;
    
    // Ensure start comes before end
    if (start.line > end.line || (start.line == end.line && start.column > end.column)) {
        std::swap(start, end);
    }
    
    std::string result;
    
    if (start.line == end.line) {
        // Single line selection
        if (start.line < (int)lines.size()) {
            result = lines[start.line].substr(start.column, end.column - start.column);
        }
    } else {
        // Multi-line selection
        for (int line = start.line; line <= end.line && line < (int)lines.size(); ++line) {
            int startCol = (line == start.line) ? start.column : 0;
            int endCol = (line == end.line) ? end.column : (int)lines[line].length();
            
            if (line > start.line) {
                result += "\n";
            }
            
            if (startCol < endCol) {
                result += lines[line].substr(startCol, endCol - startCol);
            }
        }
    }
    
    return result;
}

void CodeEditor::undo() {
    if (historyIndex > 0) {
        historyIndex--;
        if (historyIndex < (int)history.size()) {
            applyEdit(history[historyIndex], false);
        }
        modified = true;
    }
}

void CodeEditor::redo() {
    if (historyIndex < (int)history.size() - 1) {
        historyIndex++;
        applyEdit(history[historyIndex], true);
        modified = true;
    }
}

void CodeEditor::selectAll() {
    if (!lines.empty()) {
        selectionStart = Position(0, 0);
        selectionEnd = Position((int)lines.size() - 1, (int)lines.back().length());
        hasSelection = true;
        cursorPos = selectionEnd;
    }
}

void CodeEditor::copy() {
    if (hasSelection) {
        std::string selectedText = getSelectedText();
        ImGui::SetClipboardText(selectedText.c_str());
    }
}

void CodeEditor::cut() {
    if (hasSelection && !readOnlyMode) {
        std::string selectedText = getSelectedText();
        ImGui::SetClipboardText(selectedText.c_str());
        deleteSelection();
    }
}

void CodeEditor::paste() {
    if (!readOnlyMode) {
        const char* clipboardText = ImGui::GetClipboardText();
        if (clipboardText) {
            if (hasSelection) {
                deleteSelection();
            }
            insertText(clipboardText);
        }
    }
}

