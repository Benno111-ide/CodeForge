CodeEditor::CodeEditor() 
    : modified(false), readOnlyMode(false), syntaxHighlighting(true),
      lineNumbers(true), autoCompletion(false), tabSize(4), 
      hasSelection(false), mousePressed(false), isDragging(false),
      scrollY(0.0f), scrollX(0.0f), visibleLineCount(0), 
      cachedMaxLineWidth(0.0f), lineCacheDirty(true),
      historyIndex(-1) {
    selectionStart = Position(0, 0);
    selectionEnd = Position(0, 0);
    dragStartPos = Position(0, 0);
}

CodeEditor::~CodeEditor() = default;

void CodeEditor::setText(const std::string& text) {
    content = text;
    updateLines();
    cursorPos = Position(0, 0);
    modified = false;
    history.clear();
    historyIndex = -1;
}

std::string CodeEditor::getText() const {
    return content;
}

void CodeEditor::clear() {
    setText("");
}

bool CodeEditor::loadFile(const std::string& filepath) {
    std::ifstream file(filepath);
    if (!file.is_open()) return false;
    
    std::stringstream buffer;
    buffer << file.rdbuf();
    setText(buffer.str());
    
    return true;
}

bool CodeEditor::saveFile(const std::string& filepath) {
    std::ofstream file(filepath);
    if (!file.is_open()) return false;
    
    file << content;
    modified = false;
    return true;
}

void CodeEditor::updateLines() {
    lines.clear();
    
    // Invalidate line width cache when content changes
    lineCacheDirty = true;
    
    if (content.empty()) {
        lines.push_back("");
        return;
    }
    
    std::stringstream ss(content);
    std::string line;
    
    while (std::getline(ss, line)) {
        lines.push_back(line);
    }
    
    if (content.back() == '\n') {
        lines.push_back("");
    }
    
    if (lines.empty()) {
        lines.push_back("");
    }
}

void CodeEditor::render(const char* title, bool* open) {
    ImGui::SetNextWindowSize(ImVec2(800, 600), ImGuiCond_FirstUseEver);
    
    if (!ImGui::Begin(title, open)) {
        ImGui::End();
        return;
    }
    
    // Toolbar
    if (ImGui::Button("Save")) {
        // Trigger save
    }
    ImGui::SameLine();
    if (ImGui::Button("Load")) {
        // Trigger load
    }
    ImGui::SameLine();
    ImGui::Checkbox("Line Numbers", &lineNumbers);
    ImGui::SameLine();
    ImGui::Checkbox("Syntax Highlighting", &syntaxHighlighting);
    
    ImGui::Separator();
    
    // Always use custom editor to support line numbers in both modes
    renderCustomEditor();
    
    // Show status bar
    ImGui::Separator();
    ImGui::Text("Lines: %zu | Chars: %zu | Modified: %s", 
                lines.size(), content.length(), 
                modified ? "Yes" : "No");
    
    if (syntaxHighlighting) {
        ImGui::SameLine();
        ImGui::Text("| Syntax: ON");
    }
    
    if (readOnlyMode) {
        ImGui::SameLine();
        ImGui::Text("| READ-ONLY");
    }
    
    ImGui::End();
}

void CodeEditor::renderCustomEditor() {
    ImVec2 windowSize = ImGui::GetContentRegionAvail();
    windowSize.y -= ImGui::GetTextLineHeightWithSpacing(); // Leave space for status bar
    
    float lineHeight = ImGui::GetTextLineHeight();
    float lineNumberWidth = lineNumbers ? ImGui::CalcTextSize("9999").x + 10.0f : 0.0f;
    
    ImGui::BeginChild("##syntaxeditor", windowSize, true, ImGuiWindowFlags_HorizontalScrollbar);
    
    // Sync our scroll position with ImGui's scroll position
    float imguiScrollY = ImGui::GetScrollY();
    float imguiScrollX = ImGui::GetScrollX();
    
    // Only update our scroll if ImGui scroll has changed
    if (std::abs(imguiScrollY - scrollY) > 1.0f) {
        scrollY = imguiScrollY;
    }
    if (std::abs(imguiScrollX - scrollX) > 1.0f) {
        scrollX = imguiScrollX;
    }
    
    // Handle mouse wheel scrolling
    handleMouseWheel();
    
    // Update ImGui's scroll position if we've changed ours
    if (std::abs(ImGui::GetScrollY() - scrollY) > 1.0f) {
        ImGui::SetScrollY(scrollY);
    }
    if (std::abs(ImGui::GetScrollX() - scrollX) > 1.0f) {
        ImGui::SetScrollX(scrollX);
    }
    
    // Calculate visible lines
    visibleLineCount = (int)(windowSize.y / lineHeight) + 1; // +1 for partial lines
    int firstVisibleLine = getFirstVisibleLine();
    int lastVisibleLine = getLastVisibleLine();
    
    // Ensure cursor is visible when navigating
    ensureCursorVisible();
    
    ImDrawList* drawList = ImGui::GetWindowDrawList();
    ImVec2 cursorScreenPos = ImGui::GetCursorScreenPos();
    ImVec2 originalCursorPos = cursorScreenPos; // Store original position for line numbers
    
    // Apply vertical scrolling offset to content area
    cursorScreenPos.y -= scrollY;
    
    // Draw line numbers (fixed positioning)
    if (lineNumbers) {
        // Line numbers should use original position, not scrolled position
        for (int i = firstVisibleLine; i <= lastVisibleLine && i < (int)lines.size(); ++i) {
            // Calculate line number position relative to visible area
            float lineY = originalCursorPos.y + (i - firstVisibleLine) * lineHeight;
            
            // Only draw if within visible bounds
            if (lineY >= originalCursorPos.y && lineY < originalCursorPos.y + windowSize.y) {
                ImVec2 lineNumPos = ImVec2(originalCursorPos.x + 2.0f, lineY);
                
                char lineNumStr[32];
                snprintf(lineNumStr, sizeof(lineNumStr), "%4d", i + 1);
                
                ImU32 lineNumColor = ImGui::GetColorU32(ImVec4(0.6f, 0.6f, 0.7f, 1.0f));
                drawList->AddText(lineNumPos, lineNumColor, lineNumStr);
            }
        }
        
        // Draw separator line (fixed to visible area)
        ImVec2 sepStart = ImVec2(originalCursorPos.x + lineNumberWidth - 5.0f, originalCursorPos.y);
        ImVec2 sepEnd = ImVec2(sepStart.x, originalCursorPos.y + windowSize.y);
        ImU32 sepColor = ImGui::GetColorU32(ImVec4(0.4f, 0.4f, 0.5f, 1.0f));
        drawList->AddLine(sepStart, sepEnd, sepColor);
    }
    
    // Set cursor position for text content
    ImGui::SetCursorPosX(ImGui::GetCursorPosX() + lineNumberWidth);
    ImVec2 textStartPos = ImGui::GetCursorScreenPos();
    // Note: Don't apply scroll offset here - it's applied per line
    
    // Draw text content with syntax highlighting (only visible lines)
    for (int i = firstVisibleLine; i <= lastVisibleLine && i < (int)lines.size(); ++i) {
        // Calculate correct position accounting for scroll and visible line offset
        ImVec2 linePos = ImVec2(textStartPos.x - scrollX, textStartPos.y + (i - firstVisibleLine) * lineHeight);
        
        // Highlight current line
        if (i == cursorPos.line) {
            ImVec2 lineEnd = ImVec2(textStartPos.x + windowSize.x - lineNumberWidth, linePos.y + lineHeight);
            ImU32 highlightColor = ImGui::GetColorU32(ImVec4(0.2f, 0.2f, 0.3f, 0.5f));
            drawList->AddRectFilled(linePos, lineEnd, highlightColor);
        }
        
        // Draw error markers
        for (const auto& marker : errorMarkers) {
            if (marker.line == i + 1) {
                ImVec2 lineEnd = ImVec2(textStartPos.x + windowSize.x - lineNumberWidth, linePos.y + lineHeight);
                ImU32 errorColor = marker.isError ? 
                    ImGui::GetColorU32(ImVec4(1.0f, 0.0f, 0.0f, 0.3f)) :
                    ImGui::GetColorU32(ImVec4(1.0f, 1.0f, 0.0f, 0.3f));
                drawList->AddRectFilled(linePos, lineEnd, errorColor);
            }
        }
        
        // Draw text (with or without syntax highlighting)
        if (syntaxHighlighting) {
            renderLineWithSyntaxHighlighting(drawList, linePos, lines[i], i);
        } else {
            // Draw plain text without syntax highlighting
            ImU32 textColor = ImGui::GetColorU32(ImGuiCol_Text);
            drawList->AddText(linePos, textColor, lines[i].c_str());
        }
    }
    
    // Set content size for scrolling
    float totalHeight = lines.size() * lineHeight;
    
    // Use cached max line width or calculate if dirty
    if (lineCacheDirty || cachedMaxLineWidth == 0.0f) {
        cachedMaxLineWidth = 0.0f;
        // Only calculate for visible lines + a buffer for performance
        int firstLine = std::max(0, getFirstVisibleLine() - 10);
        int lastLine = std::min((int)lines.size(), getLastVisibleLine() + 10);
        
        for (int i = firstLine; i < lastLine; ++i) {
            if (i < (int)lines.size()) {
                float lineWidth = ImGui::CalcTextSize(lines[i].c_str()).x;
                cachedMaxLineWidth = std::max(cachedMaxLineWidth, lineWidth);
            }
        }
        cachedMaxLineWidth += 50.0f; // Add some padding
        lineCacheDirty = false;
    }
    
    // Draw selection
    renderSelection(drawList, textStartPos, lineHeight);
    
    // Draw cursor
    renderCursor(drawList, textStartPos, lineHeight);
    
    // Add invisible button overlay for mouse capture - positioned as overlay
    ImVec2 currentCursorPos = ImGui::GetCursorPos();
    ImGui::SetCursorPos(ImVec2(lineNumbers ? lineNumberWidth : 0.0f, 0));
    bool overlayHovered = ImGui::InvisibleButton("##editor_overlay", ImVec2(ImGui::GetContentRegionAvail().x - (lineNumbers ? lineNumberWidth : 0.0f), 
                                                      std::max(totalHeight, ImGui::GetContentRegionAvail().y)));
    
    // Restore cursor position and set proper scrolling height and width
    ImGui::SetCursorPos(currentCursorPos);
    ImGui::SetCursorPosY(totalHeight);
    
    // Set the content size for ImGui scrolling
    ImGui::Dummy(ImVec2(cachedMaxLineWidth, 0.0f)); // This sets the horizontal scroll range

    // Handle mouse input (check both window hover and overlay hover)
    handleMouseInput(textStartPos, lineHeight, overlayHovered);

    // Handle keyboard input in the custom editor area
    handleCustomEditorInput();
    
    ImGui::EndChild();
}

void CodeEditor::renderLineWithSyntaxHighlighting(ImDrawList* drawList, ImVec2 linePos, const std::string& line, size_t lineIndex) {
    (void)lineIndex; // Unused parameter
    if (line.empty()) return;
    
    float xOffset = 0;
    size_t pos = 0;
    
    while (pos < line.length()) {
        size_t tokenStart = pos;
        std::string token;
        ImU32 color = ImGui::GetColorU32(ImGuiCol_Text); // Default text color
        
        char c = line[pos];
        
        // Handle different token types
        if (c == '/' && pos + 1 < line.length() && line[pos + 1] == '/') {
            // Single-line comment - rest of line
            token = line.substr(pos);
            color = ImGui::GetColorU32(ImVec4(0.0f, 0.7f, 0.0f, 1.0f)); // Green
            pos = line.length();
        } else if (c == '/' && pos + 1 < line.length() && line[pos + 1] == '*') {
            // Multi-line comment start
            size_t end = line.find("*/", pos + 2);
            if (end != std::string::npos) {
                token = line.substr(pos, end + 2 - pos);
                pos = end + 2;
            } else {
                token = line.substr(pos);
                pos = line.length();
            }
            color = ImGui::GetColorU32(ImVec4(0.0f, 0.7f, 0.0f, 1.0f)); // Green
        } else if (c == '"') {
            // String literal
            pos++;
            while (pos < line.length() && line[pos] != '"') {
                if (line[pos] == '\\' && pos + 1 < line.length()) {
                    pos += 2; // Skip escaped character
                } else {
                    pos++;
                }
            }
            if (pos < line.length()) pos++; // Include closing quote
            token = line.substr(tokenStart, pos - tokenStart);
            color = ImGui::GetColorU32(ImVec4(1.0f, 0.8f, 0.2f, 1.0f)); // Yellow
        } else if (c == '\'') {
            // Character literal
            pos++;
            while (pos < line.length() && line[pos] != '\'') {
                if (line[pos] == '\\' && pos + 1 < line.length()) {
                    pos += 2; // Skip escaped character
                } else {
                    pos++;
                }
            }
            if (pos < line.length()) pos++; // Include closing quote
            token = line.substr(tokenStart, pos - tokenStart);
            color = ImGui::GetColorU32(ImVec4(1.0f, 0.8f, 0.2f, 1.0f)); // Yellow
        } else if (c == '#') {
            // Preprocessor directive
            while (pos < line.length() && (std::isalnum(line[pos]) || line[pos] == '_' || line[pos] == '#')) {
                pos++;
            }
            token = line.substr(tokenStart, pos - tokenStart);
            color = ImGui::GetColorU32(ImVec4(0.8f, 0.3f, 0.8f, 1.0f)); // Purple
        } else if (std::isalpha(c) || c == '_') {
            // Identifier or keyword
            while (pos < line.length() && (std::isalnum(line[pos]) || line[pos] == '_')) {
                pos++;
            }
            token = line.substr(tokenStart, pos - tokenStart);
            
            if (isKeyword(token)) {
                color = ImGui::GetColorU32(ImVec4(0.3f, 0.7f, 1.0f, 1.0f)); // Blue for keywords
            } else if (isType(token)) {
                color = ImGui::GetColorU32(ImVec4(0.4f, 0.8f, 0.4f, 1.0f)); // Light green for types
            }
        } else if (std::isdigit(c) || (c == '.' && pos + 1 < line.length() && std::isdigit(line[pos + 1]))) {
            // Number
            while (pos < line.length() && (std::isdigit(line[pos]) || line[pos] == '.' || 
                   line[pos] == 'f' || line[pos] == 'F' || line[pos] == 'l' || line[pos] == 'L' ||
                   line[pos] == 'u' || line[pos] == 'U' || line[pos] == 'x' || line[pos] == 'X' ||
                   (line[pos] >= 'a' && line[pos] <= 'f') || (line[pos] >= 'A' && line[pos] <= 'F'))) {
                pos++;
            }
            token = line.substr(tokenStart, pos - tokenStart);
            color = ImGui::GetColorU32(ImVec4(1.0f, 0.6f, 0.0f, 1.0f)); // Orange for numbers
        } else {
            // Single character (operators, punctuation, etc.)
            token = c;
            pos++;
            
            // Special colors for operators
            if (c == '+' || c == '-' || c == '*' || c == '/' || c == '=' || 
                c == '<' || c == '>' || c == '!' || c == '&' || c == '|' || 
                c == '^' || c == '~' || c == '%') {
                color = ImGui::GetColorU32(ImVec4(0.9f, 0.9f, 0.9f, 1.0f)); // White for operators
            }
        }
        
        // Draw the token (scroll offset already applied to linePos)
        ImVec2 tokenPos = ImVec2(linePos.x + xOffset, linePos.y);
        drawList->AddText(tokenPos, color, token.c_str());
        
        xOffset += ImGui::CalcTextSize(token.c_str()).x;
    }
}

