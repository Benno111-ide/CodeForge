bool CodeEditor::isKeyword(const std::string& word) const {
    static const std::vector<std::string> keywords = {
        "if", "else", "for", "while", "do", "switch", "case", "default",
        "break", "continue", "return", "goto", "typedef", "struct", "union",
        "enum", "class", "public", "private", "protected", "virtual", "static",
        "const", "volatile", "extern", "auto", "register", "sizeof", "template",
        "typename", "namespace", "using", "try", "catch", "throw", "new", "delete",
        "this", "friend", "inline", "operator", "true", "false", "nullptr",
        "constexpr", "decltype", "noexcept", "override", "final", "explicit"
    };
    return std::find(keywords.begin(), keywords.end(), word) != keywords.end();
}

bool CodeEditor::isType(const std::string& word) const {
    static const std::vector<std::string> types = {
        "void", "bool", "char", "wchar_t", "char16_t", "char32_t",
        "short", "int", "long", "signed", "unsigned",
        "float", "double", "long double",
        "size_t", "ptrdiff_t", "nullptr_t",
        "int8_t", "int16_t", "int32_t", "int64_t",
        "uint8_t", "uint16_t", "uint32_t", "uint64_t",
        "std::string", "std::vector", "std::map", "std::set",
        "std::shared_ptr", "std::unique_ptr", "std::weak_ptr"
    };
    return std::find(types.begin(), types.end(), word) != types.end();
}

bool CodeEditor::isNumber(const std::string& word) const {
    if (word.empty()) return false;
    return std::isdigit(word[0]) || (word[0] == '.' && word.length() > 1 && std::isdigit(word[1]));
}

bool CodeEditor::isString(const std::string& word) const {
    return word.length() >= 2 && 
           ((word.front() == '"' && word.back() == '"') ||
            (word.front() == '\'' && word.back() == '\''));
}

void CodeEditor::renderCursor(ImDrawList* drawList, ImVec2 textStartPos, float lineHeight) {
    if (cursorPos.line >= 0 && cursorPos.line < (int)lines.size()) {
        // Calculate cursor position with scroll offset
        float cursorX = textStartPos.x - scrollX;
        if (cursorPos.column > 0 && cursorPos.column <= (int)lines[cursorPos.line].length()) {
            std::string textUpToCursor = lines[cursorPos.line].substr(0, cursorPos.column);
            cursorX += ImGui::CalcTextSize(textUpToCursor.c_str()).x;
        }
        
        // Calculate Y position relative to visible lines
        int firstVisibleLine = getFirstVisibleLine();
        float cursorY = textStartPos.y + (cursorPos.line - firstVisibleLine) * lineHeight;
        
        // Only draw cursor if it's in visible area
        if (cursorPos.line >= firstVisibleLine && cursorPos.line <= getLastVisibleLine()) {
            // Draw cursor
            if (ImGui::IsWindowFocused()) {
                ImU32 cursorColor = ImGui::GetColorU32(ImVec4(1.0f, 1.0f, 1.0f, 1.0f));
                drawList->AddLine(
                    ImVec2(cursorX, cursorY),
                    ImVec2(cursorX, cursorY + lineHeight),
                    cursorColor,
                    2.0f
                );
            }
        }
    }
}

void CodeEditor::handleCustomEditorInput() {
    if (ImGui::IsWindowFocused() && ImGui::IsWindowHovered()) {
        ImGuiIO& io = ImGui::GetIO();
        
        // Handle keyboard shortcuts first
        if (io.KeyCtrl) {
            if (ImGui::IsKeyPressed(ImGuiKey_A)) {
                selectAll();
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_C)) {
                copy();
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_V) && !readOnlyMode) {
                paste();
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_X) && !readOnlyMode) {
                cut();
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_Z) && !readOnlyMode) {
                undo();
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_Y) && !readOnlyMode) {
                redo();
                return;
            }
            // Word navigation
            if (ImGui::IsKeyPressed(ImGuiKey_LeftArrow)) {
                moveCursorWordLeft(io.KeyShift);
                return;
            }
            if (ImGui::IsKeyPressed(ImGuiKey_RightArrow)) {
                moveCursorWordRight(io.KeyShift);
                return;
            }
        }
        
        // Handle text input
        if (io.InputQueueCharacters.Size > 0 && !readOnlyMode) {
            for (int i = 0; i < io.InputQueueCharacters.Size; i++) {
                ImWchar c = io.InputQueueCharacters[i];
                if (c == 0) break;
                if (c >= 32 && c < 127) { // Printable ASCII
                    if (hasSelection) {
                        deleteSelection();
                    }
                    insertCharacterAtCursor((char)c);
                }
            }
        }
        
        // Handle special keys
        if (!readOnlyMode && ImGui::IsKeyPressed(ImGuiKey_Enter)) {
            if (hasSelection) {
                deleteSelection();
            }
            insertCharacterAtCursor('\n');
        }
        if (!readOnlyMode && ImGui::IsKeyPressed(ImGuiKey_Backspace)) {
            if (hasSelection) {
                deleteSelection();
            } else {
                backspaceAtCursor();
            }
        }
        if (!readOnlyMode && ImGui::IsKeyPressed(ImGuiKey_Delete)) {
            if (hasSelection) {
                deleteSelection();
            } else {
                deleteAtCursor();
            }
        }
        
        // Handle navigation keys with shift for selection
        if (ImGui::IsKeyPressed(ImGuiKey_LeftArrow)) {
            moveCursorLeft(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_RightArrow)) {
            moveCursorRight(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_UpArrow)) {
            moveCursorUp(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_DownArrow)) {
            moveCursorDown(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_Home)) {
            moveCursorToLineStart(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_End)) {
            moveCursorToLineEnd(io.KeyShift);
        }
        
        // Handle Page Up/Down
        if (ImGui::IsKeyPressed(ImGuiKey_PageUp)) {
            moveCursorPageUp(io.KeyShift);
        }
        if (ImGui::IsKeyPressed(ImGuiKey_PageDown)) {
            moveCursorPageDown(io.KeyShift);
        }
        
        // Escape to clear selection
        if (ImGui::IsKeyPressed(ImGuiKey_Escape)) {
            hasSelection = false;
        }
    }
}

void CodeEditor::handleMouseInput(ImVec2 textStartPos, float lineHeight, bool overlayHovered) {
    // Check if child window is hovered or the editor overlay button is hovered
    bool editorHovered = ImGui::IsWindowHovered(ImGuiHoveredFlags_ChildWindows) || overlayHovered;
    if (!editorHovered) return;
    
    ImGuiIO& io = ImGui::GetIO();
    ImVec2 mousePos = ImGui::GetMousePos();

    // Check if mouse is in line number area (if line numbers are enabled)
    bool inLineNumberArea = false;
    if (lineNumbers) {
        if (mousePos.x < textStartPos.x) {
            inLineNumberArea = true;
        }
    }
    
    // Set appropriate cursor when hovering over text area
    if (!inLineNumberArea) {
        ImGui::SetMouseCursor(ImGuiMouseCursor_TextInput);
    }
    
    // Handle mouse clicks (only if not in line number area)
    if (ImGui::IsMouseClicked(ImGuiMouseButton_Left) && !inLineNumberArea) {
        // Capture mouse to prevent window dragging
        io.WantCaptureMouse = true;
        
        Position clickPos = screenPosToTextPos(mousePos, textStartPos, lineHeight);
        
        if (!io.KeyShift) {
            // Normal click - move cursor and clear selection
            cursorPos = clickPos;
            hasSelection = false;
        } else {
            // Shift+click - extend selection
            if (!hasSelection) {
                selectionStart = cursorPos;
                hasSelection = true;
            }
            selectionEnd = clickPos;
            cursorPos = clickPos;
        }
        
        mousePressed = true;
        isDragging = false;
        dragStartPos = clickPos;
    }
    
    // Handle mouse dragging for selection (only if not in line number area)
    if (ImGui::IsMouseDragging(ImGuiMouseButton_Left) && mousePressed && !inLineNumberArea) {
        // Capture mouse during dragging to prevent window movement
        io.WantCaptureMouse = true;
        ImGui::SetMouseCursor(ImGuiMouseCursor_TextInput);
        
        Position dragPos = screenPosToTextPos(mousePos, textStartPos, lineHeight);
        
        if (!isDragging) {
            // Start of drag - initialize selection
            isDragging = true;
            selectionStart = dragStartPos;
            hasSelection = true;
        }
        
        // Update selection end and cursor position
        selectionEnd = dragPos;
        cursorPos = dragPos;
        
        // Ensure proper selection order (start should be before end)
        if ((selectionEnd.line < selectionStart.line) ||
            (selectionEnd.line == selectionStart.line && selectionEnd.column < selectionStart.column)) {
            std::swap(selectionStart, selectionEnd);
        }
    }
    
    // Handle mouse release
    if (ImGui::IsMouseReleased(ImGuiMouseButton_Left)) {
        mousePressed = false;
        isDragging = false;
        
        // Only clear selection if we actually didn't drag (single click)
        // Don't clear selection if we have a real selection
        if (hasSelection && !isDragging && 
            selectionStart.line == selectionEnd.line && 
            selectionStart.column == selectionEnd.column) {
            hasSelection = false;
        }
    }
    
    // Handle double-click for word selection
    if (ImGui::IsMouseDoubleClicked(ImGuiMouseButton_Left)) {
        Position clickPos = screenPosToTextPos(mousePos, textStartPos, lineHeight);
        selectWordAt(clickPos);
        mousePressed = false;
        isDragging = false;
    }
    
    // Handle triple-click for line selection
    if (ImGui::IsMouseClicked(ImGuiMouseButton_Left) && ImGui::GetTime() - ImGui::GetFrameCount() / ImGui::GetIO().Framerate < 0.5f) {
        static float lastClickTime = 0.0f;
        static int clickCount = 0;
        float currentTime = ImGui::GetTime();
        
        if (currentTime - lastClickTime < 0.5f) {
            clickCount++;
        } else {
            clickCount = 1;
        }
        
        if (clickCount == 3) {
            // Triple-click: select entire line
            Position clickPos = screenPosToTextPos(mousePos, textStartPos, lineHeight);
            if (clickPos.line < (int)lines.size()) {
                selectionStart = Position(clickPos.line, 0);
                selectionEnd = Position(clickPos.line, (int)lines[clickPos.line].length());
                hasSelection = true;
                cursorPos = selectionEnd;
            }
            clickCount = 0;
        }
        
        lastClickTime = currentTime;
    }
}

CodeEditor::Position CodeEditor::screenPosToTextPos(ImVec2 screenPos, ImVec2 textStartPos, float lineHeight) {
    Position result(0, 0);
    
    // Calculate line number relative to visible lines
    int firstVisibleLine = getFirstVisibleLine();
    float relativeY = screenPos.y - textStartPos.y;
    int visibleLineIndex = (int)(relativeY / lineHeight);
    result.line = firstVisibleLine + visibleLineIndex;
    
    // Clamp to valid line range
    if (result.line < 0) result.line = 0;
    if (result.line >= (int)lines.size()) result.line = (int)lines.size() - 1;
    
    // Calculate column within the line, accounting for horizontal scroll
    if (result.line < (int)lines.size()) {
        float relativeX = (screenPos.x - textStartPos.x) + scrollX; // Add horizontal scroll offset
        result.column = 0;
        
        const std::string& line = lines[result.line];
        for (size_t i = 0; i < line.length(); ++i) {
            std::string substr = line.substr(0, i + 1);
            float textWidth = ImGui::CalcTextSize(substr.c_str()).x;
            
            if (relativeX <= textWidth) {
                result.column = (int)i;
                break;
            }
            result.column = (int)i + 1;
        }
        
        // Clamp to line length
        if (result.column > (int)line.length()) {
            result.column = (int)line.length();
        }
    }
    
    return result;
}

ImVec2 CodeEditor::textPosToScreenPos(const Position& pos, ImVec2 textStartPos, float lineHeight) {
    ImVec2 result = textStartPos;
    
    // Calculate position relative to visible lines
    int firstVisibleLine = getFirstVisibleLine();
    result.y += (pos.line - firstVisibleLine) * lineHeight;
    
    // Apply horizontal scroll offset
    if (pos.line < (int)lines.size() && pos.column > 0) {
        std::string substr = lines[pos.line].substr(0, pos.column);
        result.x += ImGui::CalcTextSize(substr.c_str()).x - scrollX;
    } else {
        result.x -= scrollX;
    }
    
    return result;
}

void CodeEditor::renderSelection(ImDrawList* drawList, ImVec2 textStartPos, float lineHeight) {
    if (!hasSelection) return;
    
    Position start = selectionStart;
    Position end = selectionEnd;
    
    // Ensure start comes before end
    if (start.line > end.line || (start.line == end.line && start.column > end.column)) {
        std::swap(start, end);
    }
    
    ImU32 selectionColor = ImGui::GetColorU32(ImVec4(0.2f, 0.4f, 0.8f, 0.3f));
    
    // Get visible line range for optimization
    int firstVisibleLine = getFirstVisibleLine();
    int lastVisibleLine = getLastVisibleLine();
    
    for (int line = std::max(start.line, firstVisibleLine); 
         line <= std::min(end.line, lastVisibleLine) && line < (int)lines.size(); ++line) {
        
        int startCol = (line == start.line) ? start.column : 0;
        int endCol = (line == end.line) ? end.column : (int)lines[line].length();
        
        if (startCol >= endCol) continue;
        
        // Calculate selection bounds with proper visible line offset
        float lineY = textStartPos.y + (line - firstVisibleLine) * lineHeight;
        
        // Calculate start X position
        float startX = textStartPos.x - scrollX;
        if (startCol > 0 && line < (int)lines.size()) {
            std::string startSubstr = lines[line].substr(0, startCol);
            startX += ImGui::CalcTextSize(startSubstr.c_str()).x;
        }
        
        // Calculate end X position
        float endX = textStartPos.x - scrollX;
        if (endCol > 0 && line < (int)lines.size()) {
            std::string endSubstr = lines[line].substr(0, endCol);
            endX += ImGui::CalcTextSize(endSubstr.c_str()).x;
        }
        
        ImVec2 selStart(startX, lineY);
        ImVec2 selEnd(endX, lineY + lineHeight);
        
        // Draw selection rectangle
        drawList->AddRectFilled(selStart, selEnd, selectionColor);
    }
}

void CodeEditor::selectWordAt(const Position& pos) {
    if (pos.line >= (int)lines.size()) return;
    
    const std::string& line = lines[pos.line];
    if (pos.column >= (int)line.length()) return;
    
    // Find word boundaries
    int start = pos.column;
    int end = pos.column;
    
    // Move start backward to beginning of word
    while (start > 0 && (std::isalnum(line[start - 1]) || line[start - 1] == '_')) {
        start--;
    }
    
    // Move end forward to end of word
    while (end < (int)line.length() && (std::isalnum(line[end]) || line[end] == '_')) {
        end++;
    }
    
    // Set selection
    selectionStart = Position(pos.line, start);
    selectionEnd = Position(pos.line, end);
    hasSelection = (start != end);
    cursorPos = selectionEnd;
}

void CodeEditor::updateSelection(const Position& oldPos, bool extend) {
    if (extend) {
        if (!hasSelection) {
            selectionStart = oldPos;
            hasSelection = true;
        }
        selectionEnd = cursorPos;
    } else {
        hasSelection = false;
    }
}

void CodeEditor::moveCursorToLineStart(bool extend) {
    Position oldPos = cursorPos;
    cursorPos.column = 0;
    updateSelection(oldPos, extend);
}

void CodeEditor::moveCursorToLineEnd(bool extend) {
    Position oldPos = cursorPos;
    if (cursorPos.line < (int)lines.size()) {
        cursorPos.column = (int)lines[cursorPos.line].length();
    }
    updateSelection(oldPos, extend);
}

void CodeEditor::moveCursorPageUp(bool extend) {
    Position oldPos = cursorPos;
    int linesPerPage = visibleLineCount > 0 ? visibleLineCount : 20; // Use actual visible lines or fallback
    cursorPos.line -= linesPerPage;
    if (cursorPos.line < 0) {
        cursorPos.line = 0;
    }
    if (cursorPos.line < (int)lines.size()) {
        if (cursorPos.column > (int)lines[cursorPos.line].length()) {
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
    updateSelection(oldPos, extend);
    ensureCursorVisible();
}

void CodeEditor::moveCursorPageDown(bool extend) {
    Position oldPos = cursorPos;
    int linesPerPage = visibleLineCount > 0 ? visibleLineCount : 20; // Use actual visible lines or fallback
    cursorPos.line += linesPerPage;
    if (cursorPos.line >= (int)lines.size()) {
        cursorPos.line = (int)lines.size() - 1;
    }
    if (cursorPos.line >= 0 && cursorPos.line < (int)lines.size()) {
        if (cursorPos.column > (int)lines[cursorPos.line].length()) {
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
    updateSelection(oldPos, extend);
    ensureCursorVisible();
}

void CodeEditor::moveCursorWordLeft(bool extend) {
    Position oldPos = cursorPos;
    
    if (cursorPos.line < (int)lines.size()) {
        const std::string& line = lines[cursorPos.line];
        
        // Move to beginning of current word or previous word
        if (cursorPos.column > 0) {
            cursorPos.column--;
            
            // Skip whitespace
            while (cursorPos.column > 0 && std::isspace(line[cursorPos.column])) {
                cursorPos.column--;
            }
            
            // Skip word characters
            while (cursorPos.column > 0 && !std::isspace(line[cursorPos.column - 1]) &&
                   (std::isalnum(line[cursorPos.column - 1]) || line[cursorPos.column - 1] == '_')) {
                cursorPos.column--;
            }
        } else if (cursorPos.line > 0) {
            // Move to end of previous line
            cursorPos.line--;
            cursorPos.column = (int)lines[cursorPos.line].length();
        }
    }
    
    updateSelection(oldPos, extend);
}

void CodeEditor::moveCursorWordRight(bool extend) {
    Position oldPos = cursorPos;
    
    if (cursorPos.line < (int)lines.size()) {
        const std::string& line = lines[cursorPos.line];
        
        // Move to end of current word or next word
        if (cursorPos.column < (int)line.length()) {
            // Skip current word
            while (cursorPos.column < (int)line.length() && 
                   (std::isalnum(line[cursorPos.column]) || line[cursorPos.column] == '_')) {
                cursorPos.column++;
            }
            
            // Skip whitespace
            while (cursorPos.column < (int)line.length() && std::isspace(line[cursorPos.column])) {
                cursorPos.column++;
            }
        } else if (cursorPos.line < (int)lines.size() - 1) {
            // Move to beginning of next line
            cursorPos.line++;
            cursorPos.column = 0;
        }
    }
    
    updateSelection(oldPos, extend);
}

// Scrolling helper methods
void CodeEditor::ensureCursorVisible() {
    float lineHeight = ImGui::GetTextLineHeight();
    if (lineHeight <= 0.0f) return;
    
    float windowHeight = ImGui::GetContentRegionAvail().y;
    int visibleLines = (int)(windowHeight / lineHeight);
    
    int firstVisible = getFirstVisibleLine();
    int lastVisible = getLastVisibleLine();
    
    // Check if cursor is above visible area
    if (cursorPos.line < firstVisible) {
        scrollY = cursorPos.line * lineHeight;
    }
    // Check if cursor is below visible area
    else if (cursorPos.line > lastVisible) {
        scrollY = (cursorPos.line - visibleLines + 1) * lineHeight;
    }
    
    // Clamp scroll to valid range
    float maxScroll = std::max(0.0f, (float)lines.size() * lineHeight - windowHeight);
    scrollY = std::max(0.0f, std::min(scrollY, maxScroll));
}

void CodeEditor::scrollTo(int line) {
    float lineHeight = ImGui::GetTextLineHeight();
    scrollY = line * lineHeight;
    
    // Clamp to valid range
    float windowHeight = ImGui::GetContentRegionAvail().y;
    float maxScroll = std::max(0.0f, (float)lines.size() * lineHeight - windowHeight);
    scrollY = std::max(0.0f, std::min(scrollY, maxScroll));
}

void CodeEditor::handleMouseWheel() {
    ImGuiIO& io = ImGui::GetIO();
    
    // Handle vertical scrolling
    if (io.MouseWheel != 0.0f) {
        float lineHeight = ImGui::GetTextLineHeight();
        if (lineHeight > 0.0f) {
            scrollY -= io.MouseWheel * lineHeight * 3.0f; // Scroll 3 lines at a time
            
            // Clamp scroll to valid range
            float windowHeight = ImGui::GetContentRegionAvail().y;
            float maxScroll = std::max(0.0f, (float)lines.size() * lineHeight - windowHeight);
            scrollY = std::max(0.0f, std::min(scrollY, maxScroll));
        }
    }
    
    // Handle horizontal scrolling (Shift + wheel or direct horizontal wheel)
    if (io.MouseWheelH != 0.0f) {
        scrollX -= io.MouseWheelH * 20.0f; // Scroll 20 pixels at a time
        scrollX = std::max(0.0f, scrollX); // Don't scroll left past 0
        
        // Optional: Add maximum horizontal scroll based on longest line
        float maxLineWidth = 0.0f;
        for (const auto& line : lines) {
            float lineWidth = ImGui::CalcTextSize(line.c_str()).x;
            maxLineWidth = std::max(maxLineWidth, lineWidth);
        }
        float windowWidth = ImGui::GetContentRegionAvail().x;
        if (lineNumbers) {
            windowWidth -= ImGui::CalcTextSize("9999").x + 10.0f;
        }
        float maxHorizontalScroll = std::max(0.0f, maxLineWidth - windowWidth + 50.0f); // +50 for margin
        scrollX = std::min(scrollX, maxHorizontalScroll);
    }
}

int CodeEditor::getFirstVisibleLine() const {
    float lineHeight = ImGui::GetTextLineHeight();
    if (lineHeight <= 0.0f) return 0; // Prevent division by zero
    
    int firstLine = (int)(scrollY / lineHeight);
    
    // Clamp to valid range
    firstLine = std::max(0, firstLine);
    firstLine = std::min(firstLine, (int)lines.size() - 1);
    
    return firstLine;
}

int CodeEditor::getLastVisibleLine() const {
    float lineHeight = ImGui::GetTextLineHeight();
    if (lineHeight <= 0.0f) return 0; // Prevent division by zero
    
    float windowHeight = ImGui::GetContentRegionAvail().y;
    int visibleLines = (int)(windowHeight / lineHeight) + 2; // +2 for partial lines
    int lastLine = getFirstVisibleLine() + visibleLines;
    
    // Clamp to valid range
    return std::min(lastLine, (int)lines.size() - 1);
}