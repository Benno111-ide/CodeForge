void CodeEditor::addToHistory(const EditAction& action) {
    // Remove any history after current index
    history.erase(history.begin() + historyIndex + 1, history.end());
    history.push_back(action);
    historyIndex = (int)history.size() - 1;
}

void CodeEditor::applyEdit(const EditAction& action, bool forward) {
    if (forward) {
        // Apply the action forward (redo)
        switch (action.type) {
            case EditAction::Insert:
                if (action.pos.line < (int)lines.size()) {
                    lines[action.pos.line].insert(action.pos.column, action.text);
                    cursorPos = Position(action.pos.line, action.pos.column + action.text.length());
                }
                break;
            case EditAction::Delete:
                if (action.pos.line < (int)lines.size()) {
                    std::string& line = lines[action.pos.line];
                    int start = std::min(action.pos.column, (int)line.length());
                    int length = action.text.length();
                    if (start + length <= line.length()) {
                        line.erase(start, length);
                    }
                    cursorPos = action.pos;
                }
                break;
            case EditAction::Replace:
                if (action.pos.line < (int)lines.size()) {
                    std::string& line = lines[action.pos.line];
                    int start = std::min(action.pos.column, (int)line.length());
                    int oldLength = action.originalText.length();
                    if (start + oldLength <= line.length()) {
                        line.erase(start, oldLength);
                        line.insert(start, action.text);
                    }
                    cursorPos = Position(action.pos.line, action.pos.column + action.text.length());
                }
                break;
        }
    } else {
        // Apply the action in reverse (undo)
        switch (action.type) {
            case EditAction::Insert:
                // To undo an insert, we delete what was inserted
                if (action.pos.line < (int)lines.size()) {
                    std::string& line = lines[action.pos.line];
                    int start = action.pos.column;
                    int length = action.text.length();
                    if (start + length <= line.length()) {
                        line.erase(start, length);
                    }
                    cursorPos = action.pos;
                }
                break;
            case EditAction::Delete:
                // To undo a delete, we insert the deleted text back
                if (action.pos.line < (int)lines.size()) {
                    lines[action.pos.line].insert(action.pos.column, action.text);
                    cursorPos = Position(action.pos.line, action.pos.column + action.text.length());
                }
                break;
            case EditAction::Replace:
                // To undo a replace, we replace back with original text
                if (action.pos.line < (int)lines.size()) {
                    std::string& line = lines[action.pos.line];
                    int start = std::min(action.pos.column, (int)line.length());
                    int newLength = action.text.length();
                    if (start + newLength <= line.length()) {
                        line.erase(start, newLength);
                        line.insert(start, action.originalText);
                    }
                    cursorPos = Position(action.pos.line, action.pos.column + action.originalText.length());
                }
                break;
        }
    }
}

